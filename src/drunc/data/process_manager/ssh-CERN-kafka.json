{
    "type": "ssh",
    "name": "SSHProcessManager",
    "command_address": "localhost:0",
    "kill_timeout": 0.5,

    "authoriser": {
        "type": "dummy"
    },

    "broadcaster": {
        "type": "kafka",
        "kafka_address": "monkafka.cern.ch:30092",
        "publish_timeout": 2
    },
    "environment": {
        "GRPC_ENABLE_FORK_SUPPORT": "false"
    },
    "opmon_uri": {
        "path": "monkafka.cern.ch:30092/opmon_stream",
        "type": "stream",
        "sleep_time" : 10
    }

}
